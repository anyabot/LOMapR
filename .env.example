# ─ Data source ────────────────────────────────────────────────────────────────
# local — read generated JSON from /data/<region>/ (dev only; uses fs)
# blob  — read JSON from Cloudflare R2 (default; what production uses)
DATA_SOURCE=local

# ─ R2 public reads (browser fetches data directly) ───────────────────────────
# The PUBLIC r2.dev URL of your bucket (NOT the S3 endpoint). Enable it in the
# Cloudflare dashboard: R2 -> bucket -> Settings -> Public access -> r2.dev.
# Exposed to the client (NEXT_PUBLIC_), so it must be the public URL.
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─ R2 admin push (server-side, used only by tools/admin/push_r2.py) ──────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
